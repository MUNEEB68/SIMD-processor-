module CPUtop(
    input clk,
    input rst,
    input  [17:0] instruction_in,
    input  [15:0] data_in,
    output reg [15:0] data_out,
    output [9:0] instruction_address,
    output reg [9:0] data_address,
    output reg data_R,
    output reg data_W,
    output done
);

assign instruction_address = PC;
assign done = (state == STATE_HALT);

// =====================================================
// FSM STATES
// =====================================================
parameter STATE_IDLE = 3'd0;
parameter STATE_IF   = 3'd1;
parameter STATE_ID   = 3'd2;
parameter STATE_EX   = 3'd3;
parameter STATE_MEM  = 3'd4;
parameter STATE_WB   = 3'd5;
parameter STATE_HALT = 3'd6;

// =====================================================
// CORE REGISTERS
// =====================================================
reg [2:0] state;
reg [9:0] PC;
reg [9:0] next_PC;

reg [15:0] H[0:3];
reg [15:0] O[0:3];
reg [15:0] Q[0:3];

reg [9:0] LC;
reg [9:0] imm;

// register fields
reg [1:0] R0, R1, R2, R3;

// =====================================================
// CONTROL SIGNALS
// =====================================================
reg add, sub, mul, mac;
reg lsl, lsr;
reg and_op, or_op, not_op;
reg load, store, set;
reg loopjmp, setloop;

// decode flags (SIMD selection)
reg H1,H2,H3;
reg O1,O2,O3;
reg Q1,Q2,Q3;

// ALU results
reg [15:0] R_add;
reg [15:0] R_mul;
reg [15:0] R_shift;
reg [15:0] R_logic;
reg [15:0] R_set;

integer i;

// =====================================================
// RESET + FSM
// =====================================================
always @(posedge clk) begin
    if(rst) begin
        state <= STATE_IDLE;
        PC <= 0;
        next_PC <= 0;
        LC <= 0;

        data_R <= 0;
        data_W <= 0;
        data_out <= 0;
        data_address <= 0;

        for(i=0;i<4;i=i+1) begin
            H[i] <= 0;
            O[i] <= 0;
            Q[i] <= 0;
        end
    end

    else begin
        case(state)

            STATE_IDLE: state <= STATE_IF;

            STATE_IF: state <= STATE_ID;

            STATE_ID: begin
                if(instruction_in[17:12] == 6'b111111)
                    state <= STATE_HALT;
                else
                    state <= STATE_EX;
            end

            STATE_EX: state <= STATE_MEM;

            STATE_MEM: state <= STATE_WB;

            STATE_WB: begin
                state <= STATE_IF;
                PC <= next_PC;
            end

            STATE_HALT: state <= STATE_HALT;

        endcase
    end
end

// =====================================================
// DECODE STAGE
// =====================================================
always @(posedge clk) begin
    if(state == STATE_ID) begin

        // reset controls
        add=0; sub=0; mul=0; mac=0;
        lsl=0; lsr=0;
        and_op=0; or_op=0; not_op=0;
        load=0; store=0; set=0;
        loopjmp=0; setloop=0;

        H1=0;H2=0;H3=0;
        O1=0;O2=0;O3=0;
        Q1=0;Q2=0;Q3=0;

        case(instruction_in[17:12])

        0,1,2,3,4,5: add = 1;
        6,7,8,9,10,11: sub = 1;
        12,13,14,15,16,17: mul = 1;
        18,19,20: mac = 1;

        21,22,23: lsl = 1;
        24,25,26: lsr = 1;

        27,28,29: and_op = 1;
        30,31,32: or_op = 1;
        33,34,35: not_op = 1;

        36: loopjmp = 1;
        37: setloop = 1;

        38,39,40: load = 1;
        41,42,43: store = 1;

        44,45,46: set = 1;

        default: ;

        endcase

        // register decode
        R0 <= instruction_in[11:10];
        R1 <= instruction_in[5:4];
        R2 <= instruction_in[3:2];
        R3 <= instruction_in[1:0];

        imm <= instruction_in[9:0];

    end
end

// =====================================================
// EXECUTE STAGE
// =====================================================
always @(posedge clk) begin
    if(state == STATE_EX) begin

        R_add = H[R0] + H[R1];
        R_mul = H[R0] * H[R1];

        R_shift = lsl ? (H[R0] << 1) :
                  lsr ? (H[R0] >> 1) : 0;

        R_logic = and_op ? (H[R0] & H[R1]) :
                  or_op  ? (H[R0] | H[R1]) :
                  not_op ? (~H[R0]) : 0;

        R_set = imm;

        // memory address
        if(load || store)
            data_address <= imm;

        // PC logic
        if(loopjmp) begin
            if(LC != 0) begin
                next_PC <= imm;
                LC <= LC - 1;
            end else begin
                next_PC <= PC + 1;
            end
        end else begin
            next_PC <= PC + 1;
        end

        if(setloop)
            LC <= imm;

    end
end

// =====================================================
// WRITE BACK STAGE
// =====================================================
always @(posedge clk) begin
    if(state == STATE_WB) begin

        if(add) H[R0] <= R_add;
        if(mul) H[R0] <= R_mul;
        if(lsl || lsr) H[R0] <= R_shift;
        if(and_op || or_op || not_op) H[R0] <= R_logic;
        if(set) H[R0] <= R_set;

        if(load) H[R0] <= data_in;

        if(store) begin
            data_out <= H[R0];
            data_W <= 1;
        end else begin
            data_W <= 0;
        end

        data_R <= load;

    end
end

endmodule